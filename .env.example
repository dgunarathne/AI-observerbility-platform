# ════════════════════════════════════════════════════════════════
#  AI Observability Platform — Environment Configuration
# ════════════════════════════════════════════════════════════════

# ─── LLM Provider ────────────────────────────────────────────────
# Choose one: openai | anthropic | ollama
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local LLM (no API key needed — docker compose --profile ollama up)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3

# ─── Detection Tuning ─────────────────────────────────────────────
ANOMALY_SENSITIVITY=0.05         # 0.01 = strict, 0.1 = loose
PREDICTION_THRESHOLD=0.75
PREDICTION_HORIZON_MINUTES=30
ALERT_COOLDOWN_MINUTES=15

# ─── Dashboard URL (used in alert links) ─────────────────────────
DASHBOARD_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════════
#  ALERT CHANNELS
# ════════════════════════════════════════════════════════════════

# ─── Slack ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#incidents

# ─── Microsoft Teams ─────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ─── Email (SMTP) ─────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password       # use App Password for Gmail
EMAIL_FROM_ADDRESS=alerts@your-domain.com
EMAIL_TO_ADDRESSES=oncall@your-domain.com,manager@your-domain.com
EMAIL_ONCALL_ADDRESSES=pager@your-domain.com   # extra recipients for CRITICAL

# ─── Twilio — SMS ────────────────────────────────────────────────
# Sign up at https://www.twilio.com (free trial available)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15551234567        # your Twilio number (E.164)
SMS_TO_NUMBERS=+15559990001,+15559990002   # comma-separated E.164

# ─── Twilio — Voice Call ─────────────────────────────────────────
# Called automatically for CRITICAL incidents
VOICE_CALL_NUMBERS=+15559990001        # who gets the call
# Optional: URL to your custom TwiML endpoint
# TWILIO_TWIML_URL=https://your-domain.com/twiml/alert

# ─── Twilio — WhatsApp ───────────────────────────────────────────
# Enable WhatsApp sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
WHATSAPP_TO_NUMBERS=+15559990001
TWILIO_WHATSAPP_FROM=+14155238886      # Twilio sandbox WhatsApp number

# ─── Discord ─────────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# ─── Telegram ────────────────────────────────────────────────────
# 1. Create a bot: message @BotFather → /newbot
# 2. Get your chat ID: message your bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFabcdef1234567890
TELEGRAM_CHAT_IDS=-1001234567890,987654321   # group or user IDs

# ─── OpsGenie ────────────────────────────────────────────────────
# API key: Settings → API key management → Add new API key
OPSGENIE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OPSGENIE_RESPONDERS=platform-team,sre-team    # OpsGenie team names

# ─── PagerDuty ───────────────────────────────────────────────────
# Integration key: Service → Integrations → Add Integration → Events API v2
PAGERDUTY_ROUTING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Generic Webhook ─────────────────────────────────────────────
# POST JSON to any URL (Zapier, IFTTT, custom services, etc.)
GENERIC_WEBHOOK_URLS=https://your-service.com/webhooks/alert
GENERIC_WEBHOOK_SECRET=optional-shared-secret

# ─── Database (auto-set by docker-compose) ────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/ai_observability
