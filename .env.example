# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (alternative)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local, no API key needed)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3

# ─── Alerting ─────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#incidents

TEAMS_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# ─── Detection Tuning ─────────────────────────────────────────────────────────
ANOMALY_SENSITIVITY=0.05         # 0.01 = strict, 0.1 = loose
PREDICTION_THRESHOLD=0.75        # confidence needed to raise a prediction alert
PREDICTION_HORIZON_MINUTES=30    # how far ahead to predict
ALERT_COOLDOWN_MINUTES=15        # suppress duplicate alerts

# ─── Database ────────────────────────────────────────────────────────────────
# Automatically set in docker-compose; override for external DB
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/ai_observability
